import json
from pathlib import Path
import requests

# 1. PASTE YOUR DISCORD WEBHOOK URL HERE
DISCORD_WEBHOOK_URL = "YOUR_SECRET_WEBHOOK_URL_HERE"

# 2. FAST TARGET API 
QUOTE_API_URL = "https://zenquotes.io/api/random"

def get_daily_quote():
    try:
        # Added a timeout of 3 seconds so the script doesn't hang if the API is slow
        response = requests.get(QUOTE_API_URL, timeout=3)
        if response.status_code == 200:
            quotes = response.json()
            first_quote = quotes[0]
            return f'"{first_quote.get("q")}"\n— {first_quote.get("a", "Unknown")}'
    except Exception:
        pass # Silently drop to fallback if the internet lags
    
    return "Make today amazing!"

def send_discord_notification(message):
    payload = {
        "content": f"**Your Daily Briefing**\n\n{message}"
    }
    
    # Added a timeout here as well for a snappy execution
    try:
        requests.post(DISCORD_WEBHOOK_URL, json=payload, timeout=3)
    except requests.exceptions.RequestException:
        print("Network timeout reached.")

if __name__ == "__main__":
    if "YOUR_SECRET" in DISCORD_WEBHOOK_URL:
        print("Setup Required: Please replace the placeholder with your actual Discord Webhook URL on Line 5.")
    else:
        daily_message = get_daily_quote()
        send_discord_notification(daily_message)
